# Penn Tennis Login Credentials (Required)
USERNAME=your_username
PASSWORD=your_password

# Reservation Settings
# PARTICIPANT must exactly match a member name in the Penn Tennis system
# (the autocomplete dropdown will search for this name)
PARTICIPANT=First Last
PREFERRED_HOUR=18
MIN_HOUR=0
MAX_HOUR=23
COURT_TYPE=outdoor
DAYS_AHEAD=7

# Browser Settings
HEADLESS=false
BROWSER_TIMEOUT=15
RETRY_ATTEMPTS=3
RETRY_DELAY=2

# Email Notifications (Optional)
EMAIL=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
